# polymarket-mcp environment configuration.
# Copy to .env and fill in your values:  cp .env.example .env

# --- Optional: server behavior ---
# The Polymarket Gamma data API is public; no credentials are required.

# API base URL (default: https://gamma-api.polymarket.com).
# POLYMARKET_BASE_URL=https://gamma-api.polymarket.com

# Comma-separated toolset names to enable, or "all" (default).
POLYMARKET_TOOLSETS=all

# "true" exposes only read-only tools.
POLYMARKET_READONLY=false

# --- Optional: trading (CLOB API) ---
# Trading moves real funds on Polygon mainnet. Leave POLYMARKET_PRIVATE_KEY
# unset to disable the trading toolset entirely and use the public Gamma data
# API only. See the disclaimer in README.md before setting this.

# Wallet private key (hex, with or without "0x") used to sign orders and
# derive CLOB API credentials. Required to enable the `trading` toolset.
# POLYMARKET_PRIVATE_KEY=

# CLOB trading API base URL (default: https://clob.polymarket.com).
# POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

# EVM chain ID for order signing (default: 137, Polygon mainnet).
# POLYMARKET_CHAIN_ID=137

# Maker/funder address holding trading funds, if different from the address
# derived from POLYMARKET_PRIVATE_KEY (e.g. a Polymarket proxy wallet).
# POLYMARKET_FUNDER_ADDRESS=

# Order signature type: 0=EOA (default), 1=proxy wallet, 2=Gnosis Safe. Must
# match how POLYMARKET_FUNDER_ADDRESS holds funds.
# POLYMARKET_SIGNATURE_TYPE=0
